{
  "manifest_version": 3,
  "name": "HAWA (Hyper Agentic Web Assistant)",
  "description": "HAWA is a cautious, agentic browsing copilot powered by Gemini 2.5 Flash.",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open HAWA"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "topbar.html",
        "topbar.js",
        "topbar.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
